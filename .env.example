# Midwest 3v3 Landing Page Generator — Environment Config (Example)
# Rename this file to .env and fill in your values.

# Admin Portal PIN (default: 1234)
PORTAL_PIN=1234

# Server port
PORT=3000

# Source site to crawl
SOURCE_URL=https://www.midwest3on3.com/leagues

# Google Tag Manager Container ID (format: GTM-XXXXXXX)
GTM_CONTAINER_ID=GTM-XXXXXXX

# Meta Pixel ID (numeric, e.g. 123456789012345)
META_PIXEL_ID=YOUR_PIXEL_ID_HERE

# Meta Conversions API (CAPI) Access Token
META_CAPI_ACCESS_TOKEN=YOUR_CAPI_ACCESS_TOKEN_HERE

# Meta CAPI Test Event Code (optional, use during testing)
META_CAPI_TEST_CODE=

# Your domain (used for CAPI event_source_url)
SITE_DOMAIN=http://localhost:3000

# Detected or manual Vercel mode (set to true to test Vercel warnings)
IS_VERCEL=false
